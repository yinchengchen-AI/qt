// Prisma 7 schema for 杭州企泰安全科技 业务管理系统
// PostgreSQL 16; soft delete via deletedAt; monetary fields @db.Decimal(18,2); time @db.Timestamptz(6)
// NOTE: Prisma 7's schema validator has known wasm issues with `enum` + `@@index` on enum fields.
//       We model enums as String columns (constrained by PG native ENUM types via raw SQL in migration)
//       and use TypeScript union types + Zod schemas for application-level type safety.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================================================
// Auth & Users
// =====================================================
model Role {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  description   String?
  permissions   Json
  isSystem      Boolean        @default(false)
  createdAt     DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @db.Timestamptz(6)
  users         User[]
  workflowTasks WorkflowTask[]

  @@index([code])
}

model User {
  id           String      @id @default(cuid())
  employeeNo   String      @unique
  name         String
  email        String      @unique
  phone        String?
  passwordHash String
  roleId       String
  role         Role        @relation(fields: [roleId], references: [id])
  departmentId String?
  department   Department? @relation("UserDepartment", fields: [departmentId], references: [id])
  status       String      @default("ACTIVE") // ACTIVE | DISABLED
  isSystem     Boolean     @default(false)
  lastLoginAt  DateTime?   @db.Timestamptz(6)
  wechatWorkId String?
  createdAt    DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime?   @db.Timestamptz(6)

  uploadedAttachments Attachment[]
  signedContracts     Contract[]   @relation("ContractSigner")

  @@index([roleId])
  @@index([status])
  @@index([departmentId])
}

// =====================================================
// Customers
// =====================================================
model Customer {
  id                      String  @id @default(cuid())
  code                    String  @unique
  name                    String
  shortName               String?
  unifiedSocialCreditCode String? @unique
  customerType            String // ENTERPRISE | GOV | OTHER
  industry                String?
  scale                   String? // LARGE | MEDIUM | SMALL | MICRO
  province                String
  city                    String
  district                String?
  address                 String?
  town                    String?

  // 主联系人信息(姓名 / 职务 / 电话);废除原 creditLimitAmount / paymentTermDays / contactEmail
  contactName   String?
  contactTitle  String?
  contactPhone  String
  sourceChannel String?
  ownerUserId   String
  status        String    @default("LEAD") // LEAD | NEGOTIATING | SIGNED | LOST | FROZEN
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)
  createdById   String
  updatedById   String
  deletedAt     DateTime? @db.Timestamptz(6)

  contracts Contract[]
  payments  Payment[]
  followUps FollowUp[]
  contacts  ContactPerson[]

  @@index([ownerUserId])
  @@index([status])
  @@index([customerType])
}

model ContactPerson {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id])
  name       String
  title      String?
  phone      String
  email      String?
  isPrimary  Boolean   @default(false)
  remark     String?
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt  DateTime? @db.Timestamptz(6)

  @@index([customerId])
}

model FollowUp {
  id           String    @id @default(cuid())
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id])
  userId       String
  followAt     DateTime  @db.Timestamptz(6)
  method       String // VISIT | CALL | WECHAT | EMAIL | OTHER
  content      String
  nextFollowAt DateTime? @db.Timestamptz(6)
  result       String? // INTENT | NO_INTENT | PENDING | SIGNED
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime? @db.Timestamptz(6)

  @@index([customerId])
  @@index([userId])
  @@index([followAt])
}

// =====================================================
// Contracts
// =====================================================
model Contract {
  id                     String    @id @default(cuid())
  contractNo             String
  // contractNo 唯一性: 软删合同不阻塞同号新建. 索引在
  // prisma/migrations/20260621_contract_no_partial_unique/migration.sql 维护
  // (CREATE UNIQUE INDEX ... WHERE "deletedAt" IS NULL). Prisma schema 不直接
  // 表达部分唯一索引, 改 schema 时不要加回 @unique.
  customerId             String
  customer               Customer  @relation(fields: [customerId], references: [id])
  customerName           String
  title                  String
  serviceType            String // SAFETY_CONSULT | SAFETY_TRAIN | HAZARD_ANA | EMERGENCY_PLAN | EVALUATION | OTHER
  signDate               DateTime  @db.Timestamptz(6)
  startDate              DateTime  @db.Timestamptz(6)
  endDate                DateTime  @db.Timestamptz(6)
  totalAmount            Decimal   @db.Decimal(18, 2)
  taxRate                Decimal   @default(0.06) @db.Decimal(6, 4)
  taxAmount              Decimal   @db.Decimal(18, 2)
  amountExcludingTax     Decimal   @db.Decimal(18, 2)
  paymentMethod          String // LUMP_SUM | BY_PHASE | BY_MONTH | BY_QUARTER
  installmentPlan        Json?
  status                 String    @default("DRAFT") // DRAFT | PENDING_REVIEW | EFFECTIVE | EXECUTING | COMPLETED | TERMINATED | EXPIRED
  ownerUserId            String
  signerId               String
  reviewerId             String?
  reviewAt               DateTime? @db.Timestamptz(6)
  reviewComment          String?
  attachments            Json
  completionInvoiceRatio Decimal   @default(0.95) @db.Decimal(4, 2)
  createdAt              DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime  @updatedAt @db.Timestamptz(6)
  createdById            String
  updatedById            String
  deletedAt              DateTime? @db.Timestamptz(6)

  projects       Project[]
  payments       Payment[]
  invoices       Invoice[]
  reviewLogs     ContractReviewLog[]
  attachmentRefs Attachment[]        @relation("ContractAttachments")
  signer         User                @relation("ContractSigner", fields: [signerId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([ownerUserId])
  @@index([signDate])
  @@index([signerId])
}

model ContractReviewLog {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])
  reviewerId String
  action     String // SUBMIT | APPROVE | REJECT | WITHDRAW
  comment    String?
  at         DateTime @default(now()) @db.Timestamptz(6)

  @@index([contractId])
}

// =====================================================
// Projects
// =====================================================
model Project {
  id            String    @id @default(cuid())
  projectNo     String    @unique
  contractId    String
  contract      Contract  @relation(fields: [contractId], references: [id])
  name          String
  serviceScope  String
  managerUserId String
  startDate     DateTime  @db.Timestamptz(6)
  endDate       DateTime  @db.Timestamptz(6)
  budgetAmount  Decimal?  @db.Decimal(18, 2)
  status        String    @default("PLANNED") // PLANNED | IN_PROGRESS | SUSPENDED | DELIVERED | ACCEPTED | CLOSED | CANCELLED
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)
  createdById   String
  updatedById   String
  deletedAt     DateTime? @db.Timestamptz(6)

  progressLogs  ProjectProgressLog[]
  taskInstances WorkflowTaskInstance[]

  @@unique([contractId, name])
  @@index([contractId])
  @@index([status])
  @@index([managerUserId])
}

model ProjectProgressLog {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String
  remark    String
  at        DateTime @default(now()) @db.Timestamptz(6)
}

// =====================================================
// Workflow Engine — 服务类型工作流 (P0: 数据模型 + seed)
// =====================================================
// 阶段(phase)固定 5 段: PREP 前期准备 / REQUIREMENT 需求识别 / CONTRACT 合同签订 / EXECUTE 实施 / FOLLOWUP 回访改进
// 任务(task)挂载在 stage 下;模板版本(isActive)控制激活态
// 实例(instance)是模板克隆到具体项目的运行时任务状态
// phase: PREP | REQUIREMENT | CONTRACT | EXECUTE | FOLLOWUP
// taskStatus: PENDING | IN_PROGRESS | COMPLETED | SKIPPED | BLOCKED
// reviewStatus: null | REVIEWING | REVIEWED | APPROVED | REJECTED (requiresTwoStepReview=true 时使用)
// recurrenceUnit: DAY | WEEK | MONTH | YEAR
model WorkflowTemplate {
  id          String    @id @default(cuid())
  serviceType String // SERVICE_TYPE
  name        String
  version     Int       @default(1)
  isActive    Boolean   @default(true)
  description String?
  createdById String
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  stages WorkflowStage[]

  @@unique([serviceType, isActive])
  @@index([serviceType])
  @@index([isActive])
}

model WorkflowStage {
  id          String           @id @default(cuid())
  templateId  String
  template    WorkflowTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  phase       String // PREP | REQUIREMENT | CONTRACT | EXECUTE | FOLLOWUP
  code        String
  name        String
  sort        Int
  description String?
  isRequired  Boolean          @default(true)

  tasks WorkflowTask[]

  @@index([templateId, phase])
}

model WorkflowTask {
  id                    String        @id @default(cuid())
  stageId               String
  stage                 WorkflowStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  code                  String
  name                  String
  sort                  Int
  description           String?
  // 期望执行角色：与 Role.code 对齐，删除 Role 时 RESTRICT（工作流里还在引用不能删）
  requiredRole          String?
  requiredRoleRef       Role?         @relation(fields: [requiredRole], references: [code], onDelete: Restrict, onUpdate: Cascade)
  requiresDeliverable   Boolean       @default(false)
  requiresOnsite        Boolean       @default(false) // 跨阶段控制点: 现场前沟通确认
  requiresTwoStepReview Boolean       @default(false) // 跨阶段控制点: 报告类校核+审核二审
  isRecurring           Boolean       @default(false)
  recurrenceUnit        String? // DAY | WEEK | MONTH | YEAR
  recurrenceInterval    Int? // 配合 unit, e.g. 1 MONTH = 每月
  estimateDays          Int?

  instances WorkflowTaskInstance[]

  @@index([stageId, sort])
  @@index([requiredRole])
}

model WorkflowTaskInstance {
  id               String       @id @default(cuid())
  projectId        String
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId           String
  task             WorkflowTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  status           String       @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | SKIPPED | BLOCKED
  assigneeId       String?
  parentInstanceId String? // 循环任务的上一个实例
  reviewStatus     String? // null | REVIEWING | REVIEWED | APPROVED | REJECTED
  reviewedById     String?
  reviewedAt       DateTime?    @db.Timestamptz(6)
  completedAt      DateTime?    @db.Timestamptz(6)
  completedById    String?
  remark           String?
  attachments      Json? // MinIO 交付物 keys
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)
  deletedAt        DateTime?    @db.Timestamptz(6)

  // 包含 parentInstanceId 让循环任务可多次出现(P2 修复)
  @@unique([projectId, taskId, parentInstanceId])
  @@index([projectId, status])
  @@index([assigneeId, status])
  @@index([parentInstanceId])
}

// =====================================================
// Invoices
// =====================================================
model Invoice {
  id                 String    @id @default(cuid())
  invoiceNo          String    @unique
  invoiceCode        String?
  contractId         String
  contract           Contract  @relation(fields: [contractId], references: [id])
  customerId         String
  customerName       String
  invoiceType        String // VAT_SPECIAL | VAT_GENERAL | VAT_ELECTRONIC | ELEC_NORMAL
  amount             Decimal   @db.Decimal(18, 2)
  taxRate            Decimal   @db.Decimal(6, 4)
  taxAmount          Decimal   @db.Decimal(18, 2)
  amountExcludingTax Decimal   @db.Decimal(18, 2)
  applyDate          DateTime  @db.Timestamptz(6)
  expectedIssueDate  DateTime? @db.Timestamptz(6)
  actualIssueDate    DateTime? @db.Timestamptz(6)
  titleType          String // COMPANY | PERSONAL
  titleName          String
  taxNo              String?
  bankName           String?
  bankAccount        String?
  address            String?
  phone              String?
  remark             String?
  attachments        Json?
  status             String    @default("DRAFT") // DRAFT | PENDING_FINANCE | ISSUED | REJECTED | VOIDED | RED_FLUSHED
  applicantUserId    String
  financeUserId      String?
  reviewedAt         DateTime? @db.Timestamptz(6)
  reviewComment      String?
  linkedInvoiceId    String?   @unique
  linkedInvoice      Invoice?  @relation("InvoiceRedFlush", fields: [linkedInvoiceId], references: [id])
  redFlushInverse    Invoice?  @relation("InvoiceRedFlush")
  createdAt          DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @db.Timestamptz(6)
  createdById        String
  updatedById        String
  deletedAt          DateTime? @db.Timestamptz(6)

  payments       Payment[]
  auditLogs      InvoiceAuditLog[]
  allocations    PaymentAllocation[]
  attachmentRefs Attachment[]        @relation("InvoiceAttachments")

  @@index([status])
  @@index([actualIssueDate])
  @@index([contractId])
  @@index([customerId])
}

model InvoiceAuditLog {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  actorId   String
  action    String
  before    Json?
  after     Json?
  comment   String?
  at        DateTime @default(now()) @db.Timestamptz(6)

  @@index([invoiceId])
}

// =====================================================
// Payments
// =====================================================
model Payment {
  id              String    @id @default(cuid())
  paymentNo       String    @unique
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])
  contractId      String
  contract        Contract  @relation(fields: [contractId], references: [id])
  invoiceId       String?
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])
  amount          Decimal   @db.Decimal(18, 2)
  receivedAt      DateTime  @db.Timestamptz(6)
  method          String // BANK_TRANSFER | CHECK | CASH | WECHAT | ALIPAY | OTHER
  bankRefNo       String? // 去 @unique；CONFIRMED 唯一由 service 校验（PLANNED 允许重复）
  bankName        String?
  remark          String?
  status          String    @default("PLANNED") // PLANNED | CONFIRMED | RECONCILED | REFUNDED | CANCELLED
  recorderUserId  String
  reconcileUserId String?
  reconciledAt    DateTime? @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)
  createdById     String
  updatedById     String
  deletedAt       DateTime? @db.Timestamptz(6)

  allocations PaymentAllocation[]

  @@index([invoiceId])
  @@index([contractId])
  @@index([status])
  @@index([receivedAt])
  @@index([customerId])
}

model PaymentAllocation {
  id        String   @id @default(cuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id])
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
  projectId String?
  amount    Decimal  @db.Decimal(18, 2)
  remark    String?
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([paymentId])
  @@index([invoiceId])
  @@index([projectId])
}

// =====================================================
// Messages / Announcements
// =====================================================
model Message {
  id             String    @id @default(cuid())
  receiverUserId String
  type           String // CONTRACT_PENDING_REVIEW | CONTRACT_EXPIRING | INVOICE_OVERDUE_PAYMENT | PAYMENT_RECEIVED | PROJECT_DUE | CUSTOMER_INACTIVE
  title          String
  content        String
  link           Json?
  readAt         DateTime? @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)

  @@index([receiverUserId, readAt])
  @@index([type])
}

model Announcement {
  id            String    @id @default(cuid())
  title         String
  content       String
  publishUserId String
  publishAt     DateTime  @default(now()) @db.Timestamptz(6)
  effectiveFrom DateTime? @db.Timestamptz(6)
  effectiveTo   DateTime? @db.Timestamptz(6)
  pinned        Boolean   @default(false)
  targetRoles   String[]
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt     DateTime? @db.Timestamptz(6)

  @@index([publishAt])
}

// =====================================================
// Audit / Dictionaries / Sequences
// =====================================================
model OperationLog {
  id       String   @id @default(cuid())
  actorId  String
  entity   String
  entityId String
  action   String
  diff     Json?
  ip       String?
  // 审计扩展字段:UA / 请求 ID / HTTP method/path / 状态 / 失败原因
  // 字段定义与迁移 prisma/migrations/20260622_operation_log_audit_fields 同步
  userAgent    String?
  requestId    String?
  method       String?
  path         String?
  status       String   @default("SUCCESS") // SUCCESS | FAILURE
  errorMessage String?
  at           DateTime @default(now()) @db.Timestamptz(6)

  @@index([actorId])
  @@index([entity, entityId])
  @@index([at])
  @@index([requestId])
  @@index([status])
}

model Dictionary {
  id         String   @id @default(cuid())
  category   String
  code       String
  label      String
  // 自引用:支持树形字典 (如 REGION: 省/市/区/街道)
  // 同 category 内 parentCode 引用上级 code,顶级为 null
  // 与 @@unique([category, code]) 联合保证 (category, parentCode, code) 在同一字典内唯一
  parentCode String?
  sort       Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  @@unique([category, code])
  @@unique([category, parentCode, code])
  @@index([category, isActive, sort])
  @@index([category, parentCode])
}

// 部门管理（树形自引用）
// 1b: 平铺 / 树形选 树形
// - parentId 自我引用形成任意层级
// - code 业务唯一,如 业务部 / 业务一部 / 业务二部
// - isActive=false 为停用,业务查询自动过滤
// - members 由 User.departmentId 反向关联计数
model Department {
  id        String       @id @default(cuid())
  code      String       @unique
  name      String
  parentId  String?
  parent    Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentTree")
  sort      Int          @default(0)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @db.Timestamptz(6)
  members   User[]       @relation("UserDepartment")

  @@index([parentId, isActive, sort])
}

model Sequence {
  id        String   @id @default(cuid())
  prefix    String
  year      Int
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([prefix, year])
}

// =====================================================
// Attachments (MinIO 对象存储索引)
// - objectKey 唯一,真实二进制存 MinIO
// - soft delete: deletedAt 不为 null 视为已删,MinIO 对象保留
// =====================================================
model Attachment {
  id           String        @id @default(cuid())
  objectKey    String        @unique
  bucket       String
  originalName String
  mimeType     String
  size         Int
  uploadedById String
  uploadedBy   User          @relation(fields: [uploadedById], references: [id])
  contractId   String?
  contract     Contract?     @relation("ContractAttachments", fields: [contractId], references: [id], onDelete: SetNull)
  invoiceId    String?
  invoice      Invoice?      @relation("InvoiceAttachments", fields: [invoiceId], references: [id], onDelete: SetNull)
  assetId      String?
  asset        CompanyAsset? @relation("AssetAttachments", fields: [assetId], references: [id], onDelete: SetNull)
  uploadedAt   DateTime      @default(now()) @db.Timestamptz(6)
  deletedAt    DateTime?     @db.Timestamptz(6)

  @@index([contractId, deletedAt])
  @@index([invoiceId, deletedAt])
  @@index([uploadedById])
  @@index([assetId, deletedAt])
  @@index([deletedAt])
}

// =====================================================
// Company Assets (企业资产库 v1)
// - 8 种 type:LICENSE|CERTIFICATE|QUALIFICATION|PERFORMANCE|TEAM_MEMBER|CASE|PATENT|OTHER
// - attributes 为类型特定字段的 JSON 容器,由 Zod 校验
// - tags 用 PG 数组列(支持 hasEvery 查询)
// - status 字段冗余存,读时由 computeAssetStatus() 重算
// =====================================================
model CompanyAsset {
  id          String    @id @default(cuid())
  code        String    @unique
  type        String
  name        String
  description String?
  attributes  Json
  tags        String[]  @default([])
  status      String    @default("VALID")
  validFrom   DateTime? @db.Timestamptz(6)
  validTo     DateTime? @db.Timestamptz(6)
  ownerUserId String
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  attachments Attachment[] @relation("AssetAttachments")

  @@index([type, status, deletedAt])
  @@index([validTo, deletedAt])
  @@index([ownerUserId])
}
