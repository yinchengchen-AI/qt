// Prisma 7 schema for 鏉窞浼佹嘲瀹夊叏绉戞妧 涓氬姟绠＄悊绯荤粺
// PostgreSQL 16; soft delete via deletedAt; monetary fields @db.Decimal(18,2); time @db.Timestamptz(6)
// NOTE: Prisma 7's schema validator has known wasm issues with `enum` + `@@index` on enum fields.
//       We model enums as String columns (constrained by PG native ENUM types via raw SQL in migration)
//       and use TypeScript union types + Zod schemas for application-level type safety.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================================================
// Auth & Users
// =====================================================
model Role {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  permissions Json
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)
  users       User[]

  @@index([code])
}

// 閫氱煡浜嬩欢绫诲瀷:涓?server/events/bus.ts 鐨?DomainEventType 涓€涓€瀵瑰簲
//   - bus.emit 鍐欏叆鐨?type 蹇呴』钀藉湪杩欓噷
//   - cron 浠诲姟鐨勫幓閲嶆煡璇篃鎸夎繖浜涘€煎尮閰?
// 澧炲噺闇€瑕佸悓姝ヤ慨鏀?server/events/bus.ts (骞惰窇 prisma migrate)
enum MessageType {
  CONTRACT_EXPIRING
  INVOICE_OVERDUE_PAYMENT
  PAYMENT_RECEIVED
  CUSTOMER_STATUS_SUGGEST
  CONTRACT_AUTO_EXECUTED
  CONTRACT_AUTO_COMPLETED
  CONTRACT_AUTO_EXPIRED
  // 鍚堝悓杩囨湡瀹介檺鏈熷己鍏?(endDate+GRACE<now 浠嶆湭缁撴竻, tryAutoCloseOnOverdue 瑙﹀彂)
  CONTRACT_AUTO_OVERDUE_TERMINATED
  // 鍚堝悓杩囨湡鏈粨娓呮彁閱?(endDate<now 浣嗛挶娌℃敹榻? tickStaleContracts 瑙﹀彂)
  CONTRACT_EXPIRED_UNPAID
  // 璇佷功 N 澶╁唴鍒版湡 (30/15/7 涓夋。闃堝€煎悇鍙戜竴娆?
  CERTIFICATE_EXPIRING
  // 瀹㈡埛鐘舵€佹満鑷姩鍖? 绯荤粺鑷姩鍐欑姸鎬?(搂1.2 / 搂3.1)
  CUSTOMER_STATUS_AUTO_APPLIED
  CUSTOMER_STATUS_AUTO_REVERTED
}

model User {
  id           String      @id @default(cuid())
  employeeNo   String      @unique
  name         String
  email        String      @unique
  phone        String?
  passwordHash String
  roleId       String
  role         Role        @relation(fields: [roleId], references: [id])
  departmentId String?
  department   Department? @relation("UserDepartment", fields: [departmentId], references: [id])
  status       String      @default("ACTIVE") // ACTIVE | DISABLED
  isSystem     Boolean     @default(false)
  lastLoginAt  DateTime?   @db.Timestamptz(6)
  wechatWorkId String?
  createdAt    DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime?   @db.Timestamptz(6)

  uploadedAttachments    Attachment[]
  signedContracts        Contract[]       @relation("ContractSigner")
  ownedContracts         Contract[]       @relation("ContractOwner")
  messages               Message[]
  publishedAnnouncements Announcement[]   @relation("AnnouncementPublishUser")
  dunningNotes           DunningNote[]
  publishedReleases      AppRelease[]       @relation("AppReleasePublishUser")
  releaseReads           AppReleaseRead[]
  profile                EmployeeProfile?

  @@index([roleId])
  @@index([status])
  @@index([departmentId])
}

model EmployeeProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 鍩虹妗ｆ
  gender        String? // MALE | FEMALE | OTHER
  birthday      DateTime? @db.Timestamptz(6)
  idCard        String?   @unique // 韬唤璇佸彿锛堟晱鎰燂紝鍔犲瘑瀛樺偍锛?
  education     String? // 瀛﹀巻瀛楀吀鍊?
  entryDate     DateTime? @db.Timestamptz(6)
  // 鍦板潃锛氱粨鏋勫寲涓虹渷/甯?鍖?+ 璇︾粏鍦板潃,鐪佸競鍖鸿蛋 lib/china-divisions.ts 涓夌骇鑱斿姩
  province      String?
  city          String?
  district      String?
  addressDetail String?

  // 浜轰簨/宀椾綅
  position         String?
  jobLevel         String?
  employmentType   String?   @default("FULL_TIME") // FULL_TIME | PART_TIME | INTERN | CONTRACTOR
  probationEndDate DateTime? @db.Timestamptz(6)
  formalDate       DateTime? @db.Timestamptz(6)
  resignationDate  DateTime? @db.Timestamptz(6)

  // 鍚堝悓
  contractType      String? // 鍚堝悓绫诲瀷瀛楀吀鍊?
  contractStartDate DateTime? @db.Timestamptz(6)
  contractEndDate   DateTime? @db.Timestamptz(6)

  // 澶村儚锛?:1 寮曠敤 Attachment锛涜蛋 avatarAttachment 鍙嶅悜 relation锛?
  avatarAttachmentId String?     @unique
  avatarAttachment   Attachment? @relation("EmployeeProfileAvatar", fields: [avatarAttachmentId], references: [id], onDelete: SetNull)

  // 鏁忔劅淇℃伅锛堜粎 ADMIN 鍙锛?
  salary                Decimal? @db.Decimal(14, 2)
  bankAccount           String? // 閾惰鍗″彿锛堟晱鎰燂紝鍔犲瘑瀛樺偍锛?
  bankName              String?
  socialSecurityAccount String? // 绀句繚璐﹀彿锛堟晱鎰燂紝鍔犲瘑瀛樺偍锛?
  providentFundAccount  String? // 鍏Н閲戣处鍙凤紙鏁忔劅锛屽姞瀵嗗瓨鍌級

  // 灞ュ巻/澶囨敞锛坵orkExperience / educationHistory / certificates 闀挎枃鏈凡杩佸埌瀛愯〃锛?
  remark String? @db.VarChar(5000)

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  // 5 寮犲瓙琛?
  educations        EmployeeEducation[]
  workExperiences   EmployeeWorkExperience[]
  certificates      EmployeeCertificate[]
  skills            EmployeeSkill[]
  emergencyContacts EmployeeEmergencyContact[]

  // 閫氱敤闄勪欢 (韬唤璇佺収 / 璇佷功闄勪欢 / 鍏朵粬) 鈥?澶氬澶氭寕鍦?Attachment.employeeProfileId
  attachments Attachment[] @relation("EmployeeProfileAttachments")

  @@index([userId])
}

// =====================================================
// 鍛樺伐妗ｆ 5 寮犲瓙琛?(PR1 of employee-profile-redesign)
// - 鍏ㄩ儴 onDelete: Cascade 鍒?EmployeeProfile
// - 鍏ㄩ儴甯?deletedAt 鏀寔杞垹 (涓庣幇鏈?EmployeeProfile 妯″紡涓€鑷?
// - certificate.attachmentId 鏄?0..1 寮曠敤,鍏佽鏃犻檮浠剁殑璇佷功
// - 璇︽儏椤?/ 鍒楄〃 / 鎺掑簭: createdAt asc / 鍚勭鏃ユ湡 desc
// =====================================================
model EmployeeEducation {
  id         String          @id @default(cuid())
  profileId  String
  profile    EmployeeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  school     String
  major      String?
  // 瀛﹀巻瀛楀吀鍊?(EDUCATION_LEVEL: HIGH_SCHOOL / JUNIOR_COLLEGE / BACHELOR / MASTER / DOCTORATE / OTHER)
  degree     String?
  startDate  DateTime        @db.Timestamptz(6)
  endDate    DateTime?       @db.Timestamptz(6)
  isFullTime Boolean         @default(true)
  remark     String?         @db.VarChar(2000)
  createdAt  DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime        @updatedAt @db.Timestamptz(6)
  deletedAt  DateTime?       @db.Timestamptz(6)

  @@index([profileId])
}

model EmployeeWorkExperience {
  id          String          @id @default(cuid())
  profileId   String
  profile     EmployeeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company     String
  position    String?
  startDate   DateTime        @db.Timestamptz(6)
  endDate     DateTime?       @db.Timestamptz(6)
  leaveReason String?
  referrer    String?
  remark      String?         @db.VarChar(2000)
  createdAt   DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime        @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime?       @db.Timestamptz(6)

  @@index([profileId])
}

model EmployeeCertificate {
  id           String          @id @default(cuid())
  profileId    String
  profile      EmployeeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name         String
  number       String?
  issuer       String?
  issueDate    DateTime?       @db.Timestamptz(6)
  // expiryDate 绱㈠紩缁欒瘉涔﹀埌鏈?cron 鐢?(server/jobs/certificate-expiry-check)
  expiryDate   DateTime?       @db.Timestamptz(6)
  attachmentId String?
  attachment   Attachment?     @relation("CertificateAttachment", fields: [attachmentId], references: [id], onDelete: SetNull)
  remark       String?         @db.VarChar(2000)
  createdAt    DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime        @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime?       @db.Timestamptz(6)

  @@index([profileId])
  @@index([expiryDate])
}

model EmployeeSkill {
  id         String          @id @default(cuid())
  profileId  String
  profile    EmployeeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name       String
  // BEGINNER | INTERMEDIATE | ADVANCED
  level      String          @default("INTERMEDIATE")
  obtainDate DateTime?       @db.Timestamptz(6)
  remark     String?         @db.VarChar(2000)
  createdAt  DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime        @updatedAt @db.Timestamptz(6)
  deletedAt  DateTime?       @db.Timestamptz(6)

  @@index([profileId])
}

// PR9:璇佷功鍒版湡鎻愰啋鐨勫幓閲嶈〃(鏇夸唬 Redis 缂撳瓨)
// 姣忔潯璁板綍琛ㄧず"鏌愯瘉涔︽煇闃堝€煎凡鍙戣繃涓€娆￠€氱煡",@@unique 闃查噸澶?
model CertificateExpiryNotice {
  id            String   @id @default(cuid())
  certificateId String
  threshold     Int
  sentAt        DateTime @default(now()) @db.Timestamptz(6)

  @@unique([certificateId, threshold])
  @@index([certificateId])
  @@index([sentAt])
}

model EmployeeEmergencyContact {
  id           String          @id @default(cuid())
  profileId    String
  profile      EmployeeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name         String
  // 鍏崇郴: 鐖舵瘝/閰嶅伓/鍏勫紵濮愬/瀛愬コ/鍏朵粬
  relationship String
  phone        String
  remark       String?         @db.VarChar(500)
  createdAt    DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime        @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime?       @db.Timestamptz(6)

  @@index([profileId])
}

// =====================================================
// Customers
// =====================================================
model Customer {
  id                      String  @id @default(cuid())
  code                    String  @unique
  name                    String
  shortName               String?
  unifiedSocialCreditCode String? @unique
  customerType            String // ENTERPRISE | GOV | OTHER
  industry                String?
  scale                   String? // LARGE | MEDIUM | SMALL | MICRO
  province                String
  city                    String
  district                String?
  address                 String?
  town                    String?

  // 涓昏仈绯讳汉淇℃伅(濮撳悕 / 鑱屽姟 / 鐢佃瘽);搴熼櫎鍘?creditLimitAmount / paymentTermDays / contactEmail
  contactName   String?
  contactTitle  String?
  contactPhone  String
  sourceChannel String?
  ownerUserId   String
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)
  createdById   String
  updatedById   String
  deletedAt     DateTime? @db.Timestamptz(6)

  contracts Contract[]
  payments  Payment[]
  followUps FollowUp[]
  contacts  ContactPerson[]

  @@index([ownerUserId])
  @@index([customerType])
}

model ContactPerson {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id])
  name       String
  title      String?
  phone      String
  email      String?
  isPrimary  Boolean   @default(false)
  remark     String?
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt  DateTime? @db.Timestamptz(6)

  @@index([customerId])
}

// @deprecated 2026-06: 瀹㈡埛璺熻繘 (FollowUp) 鍔熻兘宸蹭笅绾? API 鍏ㄩ儴杩斿洖 410, UI 宸查殣钘?
// 鐘舵€佹満寤鸿淇″彿鏀圭敤 lastActivityAt (鍚堝悓/鍥炴/瀹㈡埛鏇存柊鏃堕棿) 鈥?瑙?server/jobs/customer-status-suggest.ts.
// 琛ㄧ粨鏋勪繚鐣欐槸涓轰簡鍘嗗彶鏁版嵁鍙煡; 鍚庣画娓呯悊鏁版嵁鍙蛋 scripts/shared/cleanup-business-data.ts.
// 鏂板姛鑳戒笉瑕佸啀璇诲啓姝よ〃.
model FollowUp {
  id           String    @id @default(cuid())
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id])
  userId       String
  followAt     DateTime  @db.Timestamptz(6)
  method       String // VISIT | CALL | WECHAT | EMAIL | OTHER
  content      String
  nextFollowAt DateTime? @db.Timestamptz(6)
  result       String? // INTENT | NO_INTENT | PENDING | SIGNED
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime? @db.Timestamptz(6)

  @@index([customerId])
  @@index([userId])
  @@index([followAt])
}

// =====================================================
// Contracts
// =====================================================
model Contract {
  id                     String    @id @default(cuid())
  contractNo             String
  // contractNo 鍞竴鎬? 杞垹鍚堝悓涓嶉樆濉炲悓鍙锋柊寤? 绱㈠紩鍦?
  // prisma/migrations/20260621_contract_no_partial_unique/migration.sql 缁存姢
  // (CREATE UNIQUE INDEX ... WHERE "deletedAt" IS NULL). Prisma schema 涓嶇洿鎺?
  // 琛ㄨ揪閮ㄥ垎鍞竴绱㈠紩, 鏀?schema 鏃朵笉瑕佸姞鍥?@unique.
  customerId             String
  customer               Customer  @relation(fields: [customerId], references: [id])
  customerName           String
  title                  String
  serviceType            String // SAFETY_CONSULT | SAFETY_TRAIN | HAZARD_ANA | EMERGENCY_PLAN | EVALUATION | OTHER
  signDate               DateTime  @db.Timestamptz(6)
  startDate              DateTime  @db.Timestamptz(6)
  endDate                DateTime  @db.Timestamptz(6)
  totalAmount            Decimal   @db.Decimal(18, 2)
  taxRate                Decimal   @default(0.06) @db.Decimal(6, 4)
  taxAmount              Decimal   @db.Decimal(18, 2)
  amountExcludingTax     Decimal   @db.Decimal(18, 2)
  paymentMethod          String // LUMP_SUM | BY_PHASE | BY_MONTH | BY_QUARTER
  installmentPlan        Json?
  // 鍚堝悓浜や粯鐗╀笉鍐嶄互缁撴瀯鍖?JSON 瀛? 瀹為檯浜や粯鏂囦欢璧?Attachment.isDeliverable=true
  // (admin / 绛捐浜?/ 璐熻矗浜?涓夎€呬箣涓€ 鎵嶈兘涓婁紶; 璇﹁ server/storage/presign.ts assertCanManageDeliverables)
  status                 String    @default("DRAFT") // DRAFT | ACTIVE | CLOSED
  ownerUserId            String
  signerId               String
  reviewerId             String?
  reviewAt               DateTime? @db.Timestamptz(6)
  reviewComment          String?
  // 鍚堝悓澶囨敞: 鑷敱鏂囨湰, 璺?reviewComment (瀹℃壒鎰忚) 鍖哄垎; 涓嶅弬涓庣姸鎬佹満/瀹℃壒娴?
  remark                 String?
  attachments            Json
  completionInvoiceRatio Decimal   @default(0.95) @db.Decimal(4, 2)
  // legacy-fineui.mjs 杩佺Щ鏃舵妸 ContractAmount<=0 鐨勫悎鍚?totalAmount 鍐欐垚 0.01 鍗犱綅鍊?
  // 杩欓噷鏍?true 璁╃粺璁?鍒楄〃榛樿鎺掗櫎(鍙粡 includeLegacyZeroAmount=true 鏄惧紡鍖呭惈). 璇﹁ migration 20260705.
  isLegacyZeroAmount    Boolean   @default(false)
  createdAt              DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime  @updatedAt @db.Timestamptz(6)
  createdById            String
  updatedById            String
  deletedAt              DateTime? @db.Timestamptz(6)

  payments       Payment[]
  invoices       Invoice[]
  reviewLogs     ContractReviewLog[]
  attachmentRefs Attachment[]        @relation("ContractAttachments")
  signer         User                @relation("ContractSigner", fields: [signerId], references: [id])
  owner          User                @relation("ContractOwner", fields: [ownerUserId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([ownerUserId])
  @@index([signDate])
  @@index([signerId])
  @@index([isLegacyZeroAmount])
}

model ContractReviewLog {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])
  reviewerId String
  action     String // SUBMIT | APPROVE | REJECT | WITHDRAW
  comment    String?
  at         DateTime @default(now()) @db.Timestamptz(6)

  @@index([contractId])
}

// =====================================================
// Invoices
// =====================================================
model Invoice {
  id                 String    @id @default(cuid())
  invoiceNo          String    @unique
  invoiceCode        String?
  contractId         String
  contract           Contract  @relation(fields: [contractId], references: [id])
  customerId         String
  customerName       String
  invoiceType        String // VAT_SPECIAL | VAT_GENERAL | VAT_ELECTRONIC | ELEC_NORMAL
  amount             Decimal   @db.Decimal(18, 2)
  taxRate            Decimal   @db.Decimal(6, 4)
  taxAmount          Decimal   @db.Decimal(18, 2)
  amountExcludingTax Decimal   @db.Decimal(18, 2)
  applyDate          DateTime  @db.Timestamptz(6)
  expectedIssueDate  DateTime? @db.Timestamptz(6)
  actualIssueDate    DateTime? @db.Timestamptz(6)
  // 鍚堝悓绾﹀畾浠樻鏃?璐﹂緞 basis=due 鐢?;涓?null 鏃跺洖閫€鍒?actualIssueDate 璁￠緞
  dueDate            DateTime? @db.Timestamptz(6)
  titleType          String // COMPANY | PERSONAL
  titleName          String
  taxNo              String?
  bankName           String?
  bankAccount        String?
  address            String?
  phone              String?
  remark             String?
  status             String    @default("DRAFT") // DRAFT | PENDING_FINANCE | ISSUED | REJECTED | VOIDED | RED_FLUSHED
  applicantUserId    String
  financeUserId      String?
  reviewComment      String?
  attachments        Json      @default("[]")
  linkedInvoiceId    String?   @unique
  linkedInvoice      Invoice?  @relation("InvoiceRedFlush", fields: [linkedInvoiceId], references: [id])
  redFlushInverse    Invoice?  @relation("InvoiceRedFlush")
  createdAt          DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @db.Timestamptz(6)
  createdById        String
  updatedById        String
  deletedAt          DateTime? @db.Timestamptz(6)

  payments       Payment[]
  auditLogs      InvoiceAuditLog[]
  attachmentRefs Attachment[]      @relation("InvoiceAttachments")
  dunningNotes   DunningNote[]

  @@index([status])
  @@index([actualIssueDate])
  @@index([dueDate])
  @@index([contractId])
  @@index([customerId])
}

model InvoiceAuditLog {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  actorId   String
  action    String
  before    Json?
  after     Json?
  comment   String?
  at        DateTime @default(now()) @db.Timestamptz(6)

  @@index([invoiceId])
}

// =====================================================
// Payments
// =====================================================
model Payment {
  id              String    @id @default(cuid())
  paymentNo       String    @unique
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id])
  contractId      String
  contract        Contract  @relation(fields: [contractId], references: [id])
  invoiceId       String?
  invoice         Invoice?  @relation(fields: [invoiceId], references: [id])
  amount          Decimal   @db.Decimal(18, 2)
  receivedAt      DateTime  @db.Timestamptz(6)
  method          String // BANK_TRANSFER | CHECK | CASH | WECHAT | ALIPAY | OTHER
  bankRefNo       String? // 鍘?@unique锛汣ONFIRMED 鍞竴鐢?service 鏍￠獙锛圥LANNED 鍏佽閲嶅锛?
  bankName        String?
  remark          String?
  status          String    @default("PLANNED") // PLANNED | CONFIRMED | RECONCILED | REFUNDED | CANCELLED
  recorderUserId  String
  reconcileUserId String?
  reconciledAt    DateTime? @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)
  createdById     String
  updatedById     String
  deletedAt       DateTime? @db.Timestamptz(6)

  @@index([invoiceId])
  @@index([contractId])
  @@index([status])
  @@index([receivedAt])
  @@index([customerId])
}

// =====================================================
// Messages / Announcements
// =====================================================
model Message {
  id             String      @id @default(cuid())
  receiverUserId String
  receiver       User        @relation(fields: [receiverUserId], references: [id], onDelete: Restrict)
  type           MessageType
  title          String      @db.VarChar(200)
  content        String      @db.VarChar(10000)
  link           Json?
  readAt         DateTime?   @db.Timestamptz(6)
  createdAt      DateTime    @default(now()) @db.Timestamptz(6)

  @@index([receiverUserId, readAt])
  // 鍘婚噸鏌ヨ:`type + receiverUserId + createdAt + JSON link.id`
  // 杩欎釜澶嶅悎绱㈠紩鎶婃壂鎻忔敹鏁涘埌"浠婂ぉ + 璇ョ敤鎴?+ 璇ョ被鍨?鐨勫皬绐楀彛,JSON 璺緞鍐嶄簩娆¤繃婊?
  @@index([type, receiverUserId, createdAt])
}

model Announcement {
  id            String    @id @default(cuid())
  title         String    @db.VarChar(200)
  content       String    @db.VarChar(10000)
  publishUserId String
  publishUser   User      @relation("AnnouncementPublishUser", fields: [publishUserId], references: [id], onDelete: Restrict)
  publishAt     DateTime  @default(now()) @db.Timestamptz(6)
  effectiveFrom DateTime? @db.Timestamptz(6)
  effectiveTo   DateTime? @db.Timestamptz(6)
  pinned        Boolean   @default(false)
  targetRoles   String[]
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt     DateTime? @db.Timestamptz(6)

  @@index([publishAt])
}

// =====================================================
// Audit / Dictionaries / Sequences
// =====================================================
model OperationLog {
  id           String   @id @default(cuid())
  actorId      String
  entity       String
  entityId     String
  action       String
  diff         Json?
  ip           String?
  // 瀹¤鎵╁睍瀛楁:UA / 璇锋眰 ID / HTTP method/path / 鐘舵€?/ 澶辫触鍘熷洜
  // 瀛楁瀹氫箟涓庤縼绉?prisma/migrations/20260622_operation_log_audit_fields 鍚屾
  userAgent    String?
  requestId    String?
  method       String?
  path         String?
  status       String   @default("SUCCESS") // SUCCESS | FAILURE
  errorMessage String?
  at           DateTime @default(now()) @db.Timestamptz(6)

  @@index([actorId])
  @@index([entity, entityId])
  @@index([at])
  @@index([requestId])
  @@index([status])
}

model Dictionary {
  id         String   @id @default(cuid())
  category   String
  code       String
  label      String
  // 鑷紩鐢?鏀寔鏍戝舰瀛楀吀 (濡?REGION: 鐪?甯?鍖?琛楅亾)
  // 鍚?category 鍐?parentCode 寮曠敤涓婄骇 code,椤剁骇涓?null
  // 涓?@@unique([category, code]) 鑱斿悎淇濊瘉 (category, parentCode, code) 鍦ㄥ悓涓€瀛楀吀鍐呭敮涓€
  parentCode String?
  sort       Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  @@unique([category, code])
  @@unique([category, parentCode, code])
  @@index([category, isActive, sort])
  @@index([category, parentCode])
}

// 閮ㄩ棬绠＄悊锛堟爲褰㈣嚜寮曠敤锛?
// 1b: 骞抽摵 / 鏍戝舰閫?鏍戝舰
// - parentId 鑷垜寮曠敤褰㈡垚浠绘剰灞傜骇
// - code 涓氬姟鍞竴,濡?涓氬姟閮?/ 涓氬姟涓€閮?/ 涓氬姟浜岄儴
// - isActive=false 涓哄仠鐢?涓氬姟鏌ヨ鑷姩杩囨护
// - members 鐢?User.departmentId 鍙嶅悜鍏宠仈璁℃暟
model Department {
  id        String       @id @default(cuid())
  code      String       @unique
  name      String
  parentId  String?
  parent    Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentTree")
  sort      Int          @default(0)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @db.Timestamptz(6)
  members   User[]       @relation("UserDepartment")

  @@index([parentId, isActive, sort])
}

model Sequence {
  id        String   @id @default(cuid())
  prefix    String
  year      Int
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([prefix, year])
}

// =====================================================
// Attachments (MinIO 瀵硅薄瀛樺偍绱㈠紩)
// - objectKey 鍞竴,鐪熷疄浜岃繘鍒跺瓨 MinIO
// - soft delete: deletedAt 涓嶄负 null 瑙嗕负宸插垹,MinIO 瀵硅薄淇濈暀
// =====================================================
model Attachment {
  id                     String                @id @default(cuid())
  objectKey              String                @unique
  bucket                 String
  originalName           String
  mimeType               String
  size                   Int
  uploadedById           String
  uploadedBy             User                  @relation(fields: [uploadedById], references: [id])
  contractId             String?
  contract               Contract?             @relation("ContractAttachments", fields: [contractId], references: [id], onDelete: SetNull)
  invoiceId              String?
  invoice                Invoice?              @relation("InvoiceAttachments", fields: [invoiceId], references: [id], onDelete: SetNull)
  employeeProfileId      String?
  employeeProfile        EmployeeProfile?      @relation("EmployeeProfileAttachments", fields: [employeeProfileId], references: [id], onDelete: SetNull)
  // 鍙嶅悜锛氬憳宸ュご鍍?(1:1)
  avatarOfProfile        EmployeeProfile?      @relation("EmployeeProfileAvatar")
  // 鍙嶅悜锛氳瘉涔﹂檮浠?(1:N)
  certificateAttachments EmployeeCertificate[] @relation("CertificateAttachment")
  // 鍚堝悓浜や粯鐗╅檮浠舵爣璁? true 琛ㄧず璇ラ檮浠舵槸鍚堝悓璇︽儏"浜や粯鐗?tab 涓婁紶鐨勪氦浠樻枃浠?(鎶ュ憡/璇佷功/鍩硅鏉愭枡 绛?,
  //   鍐欐潈闄愪粎 admin / 绛捐浜?/ 璐熻矗浜?(assertCanManageDeliverables);
  // false 琛ㄧず鍚堝悓閫氱敤闄勪欢 (璧?闄勪欢"tab, 娌跨敤 admin / 涓婁紶鑰?鍒犻櫎瑙勫垯)
  isDeliverable          Boolean               @default(false)
  // 闄勪欢鍒嗙被: GENERAL(榛樿閫氱敤) / AVATAR(澶村儚) / ID_CARD_FRONT/BACK(韬唤璇佹鍙嶉潰) / CERTIFICATE(璇佷功鎵弿浠?
  // 鍐欏叆鐢?/api/files/presign-upload 鐨?body.category 鍐冲畾;璇诲彇鎸?category 杩囨护
  category               String                @default("GENERAL")
  uploadedAt             DateTime              @default(now()) @db.Timestamptz(6)
  deletedAt              DateTime?             @db.Timestamptz(6)

  @@index([contractId, deletedAt])
  @@index([invoiceId, deletedAt])
  @@index([employeeProfileId, deletedAt])
  @@index([uploadedById])
  @@index([contractId, isDeliverable, deletedAt])
  @@index([deletedAt])
}

// =====================================================
// 鍌敹璁板綍
//   - 涓?Invoice 1:N (cascade delete, 鍙戠エ鍒犻櫎鍒欏偓鏀惰褰曚竴璧峰垹)
//   - 涓?User N:1 (actor 璁板綍璋佸垱寤? restrict 闃叉 actor 璇垹瀵艰嚧鍘嗗彶澶变富)
//   - status: CONTACTED(宸茶仈绯? | PROMISED(瀹㈡埛鎵胯) | DISPUTED(浜夎) | LEGAL(娉曞姟浠嬪叆)
//   - promisedDate: 瀹㈡埛鎵胯浠樻鏃?鍙┖,鍙湁 PROMISED 鏃跺～)
//   - lastContactAt: 鏈€杩戜竴娆¤仈绯绘椂闂?鐢ㄤ簬"璺濅笂娆¤窡杩?N 澶?鎻愰啋)
//   - channel: PHONE | WECHAT | EMAIL | VISIT
// =====================================================
model DunningNote {
  id            String    @id @default(cuid())
  invoiceId     String
  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  status        String // CONTACTED | PROMISED | DISPUTED | LEGAL
  promisedDate  DateTime? @db.Timestamptz(6)
  lastContactAt DateTime  @db.Timestamptz(6)
  channel       String // PHONE | WECHAT | EMAIL | VISIT
  remark        String?
  actorId       String
  actor         User      @relation(fields: [actorId], references: [id], onDelete: Restrict)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)

  @@index([invoiceId])
  @@index([status])
  @@index([actorId, createdAt])
}

// =====================================================
// AppRelease (搴旂敤鏇存柊璁板綍 / 鍙戝竷鏃ュ織)
//   - 椤圭洰姣忔鍙戠増鍚?绠＄悊鍛樺湪姝よ褰?鏈鏇存柊鍐呭/淇/浼樺寲"銆?
//   - 鐢ㄦ埛鐧诲綍鍚?鑻ュ瓨鍦?publishedAt 鏅氫簬璇ョ敤鎴蜂笂娆″凡璇绘椂闂寸殑 release,
//     鍦?DashboardShell 寮瑰嚭鏇存柊璇存槑(瑙?components/release-popup.tsx)銆?
//   - AppReleaseRead: per-user 宸茶鏃堕棿;鍚屼竴 release + user 鍞竴,閬垮厤閲嶅璁℃暟銆?
//   - 涓?Announcement 鐨勫尯鍒?
//       * Announcement 鏄竴娆℃€у叕鍛?(鏈夌敓鏁堟湡 / 鐩爣瑙掕壊 / 缃《)
//       * AppRelease 鏄竴鏉″彂鐗堟棩蹇?(鎸?publishedAt 鍊掑簭灞曠ず,鍏ㄥ憳鍙)
//   - 涓嶆寕 RLS: 鎵€鏈夌櫥褰曠敤鎴烽兘搴旇鐪嬪埌鍏ㄩ儴 release(鎸?publishedAt + 宸茶鐘舵€?
//     鍐冲畾 popup 鏄惁寮瑰嚭,涓嶉渶瑕佽绾ч殧绂?銆?
// =====================================================
model AppRelease {
  id            String    @id @default(cuid())
  // 鐗堟湰鍙?濡?"v0.7.0";鍏佽鑷敱濉啓,浣嗘湰椤圭洰榛樿鎸?package.json 鍚屾銆?
  version       String    @db.VarChar(50)
  title         String    @db.VarChar(200)
  // 姒傝:鍗＄墖/鍒楄〃鐨?1-2 琛岀畝浠?<=500 瀛楃)
  summary       String    @db.VarChar(500)
  // 璇︽儏:鏀寔鎹㈣鐨?Markdown 鏂囨湰(<=10000),鍦ㄥ脊绐?璇︽儏椤电敤鐧藉悕鍗曟覆鏌撱€?
  content       String    @db.VarChar(10000)
  // 鏄惁"閲嶈"鏇存柊:important=true 鏃?鍗充娇宸茶,椤堕儴浠嶅睍绀虹孩鐐规彁绀虹敤鎴峰洖椤?
  // (popup 鐨勮瑙夋潈閲嶄笉鍚? important 鈫?澶у脊绐? normal 鈫?灏忔彁绀?
  important     Boolean   @default(false)
  publishedAt   DateTime  @default(now()) @db.Timestamptz(6)
  publishedById String
  publishedBy   User      @relation("AppReleasePublishUser", fields: [publishedById], references: [id], onDelete: Restrict)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt     DateTime? @db.Timestamptz(6)
  reads         AppReleaseRead[]

  // 鏉ユ簮:MANUAL 绠＄悊鍛樻墜鏁?GIT_COMMITS 浠?git log 鑷姩鐢熸垚 (scripts/release/generate.ts)
  // - MANUAL 涓烘棫鏁版嵁 / 绱ф€ヨˉ涓佺殑鍏煎鍊?鏂扮増鏈簲浼樺厛鐢?GIT_COMMITS
  // - gitFrom/gitTo 璁板綍璇?release 瑕嗙洊鐨?commit 鍖洪棿(鍙┖:鎵嬫暡鐨?release 娌℃簮)
  // - gitCommitCount 鐢ㄤ簬鍒楄〃灞曠ず"鍩轰簬 N 涓?commit",杈呭姪瀹¤
  source          String    @default("MANUAL")
  gitFrom         String?   @db.VarChar(40)
  gitTo           String?   @db.VarChar(40)
  gitCommitCount  Int?

  @@index([publishedAt])
  @@index([deletedAt])
  @@index([important, publishedAt])
  @@index([source])
}

// 鐢ㄦ埛瀵逛竴鏉?release 鐨?宸茶"璁板綍銆?
// - unique(userId, releaseId) 闃查噸澶?
// - 涓嶆寕 deletedAt: 鐢ㄦ埛鎾ら攢宸茶 = 鍒犺;鏃犻渶杞垹(瀹¤鎰忎箟涓嶅ぇ)銆?
model AppReleaseRead {
  id        String     @id @default(cuid())
  userId    String
  releaseId String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  release   AppRelease @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  readAt    DateTime   @default(now()) @db.Timestamptz(6)

  @@unique([userId, releaseId])
  @@index([userId, readAt])
  @@index([releaseId])
}
